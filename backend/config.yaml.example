server:
  cors_origins:
    - http://localhost:5173
  session_secret: ${SESSION_SECRET}

auth:
  enabled: true
  post_login_redirect: http://localhost:5173
  oidc:
    issuer_url: http://localhost:8080/realms/spliffy
    client_id: spliffy
    client_secret: ${OIDC_CLIENT_SECRET}
    redirect_uri: http://localhost:5173/api/auth/callback
    scopes:
      - openid
      - profile
      - email

dify:
  enabled: false
  name: Spliffy
  # Per-locale grammatical forms (default = branding; message = "Message X" / "Napsat X")
  name_forms:
    en:
      default: Spliffy
      message: Spliffy
    cs:
      default: Spliffy
      message: Spliffy
  # Example for a personal assistant named Sofie:
  # name: Sofie
  # name_forms:
  #   cs:
  #     default: Sofie
  #     message: Sofii   # "Napsat Sofii" not "Napsat Sofie"
  markdown: false
  show_sources: true
  # Self-hosted example: http://127.0.0.1/v1 or http://api:5001/v1 from another container
  base_url: http://127.0.0.1/v1
  api_key: ${DIFY_API_KEY}

# Optional: resolve citation URLs from RAGFlow when Dify agent logs contain document_id
# but message_end lacks retriever_resources (common with RAGFlow plugin retrieval).
ragflow:
  enabled: false
  api_url: http://127.0.0.1:9380
  api_key: ${RAGFLOW_API_KEY}
  default_dataset_id: ""
  dataset_name: RAGFlow

# Optional: override frontend UI strings per instance (no image rebuild required).
# Prefer a ui_strings/ directory with one YAML file per locale (see backend/ui_strings/README.md).
# When omitted, the bundled i18n defaults are used.
ui_strings:
  default_locale: cs
  path: ui_strings
  # Inline overrides (optional; merged on top of locale files):
  # chat:
  #   hint:
  #     cs: "Toto je AI asistent. Může dělat chyby — ověřte důležité informace."

tool_labels:
  enabled: false
  default_locale: cs
  default:
    cs: "Používám {{tool}}"
    en: "Using {{tool}}"
  tools:
    retrieval:
      cs: "Hledám v dokumentech: {{query}}"
      en: "Searching documents: {{query}}"
    get_law_excerpt:
      cs: "Ověřuji legislativu: {{reference}} § {{paragraph}}"
      en: "Evaluating law: {{reference}} § {{paragraph}}"
